<Project ToolsVersion="15.0">
  <!-- Dependency versions -->
  <PropertyGroup>
    <NuGetPackageVersion>7.3.0</NuGetPackageVersion>
    <NuGetTestHelpersVersion>2.1.39</NuGetTestHelpersVersion>
    <CommandLineUtilsVersion>5.0.1</CommandLineUtilsVersion>
    <FileSystemGlobbingVersion>10.0.3</FileSystemGlobbingVersion>
  </PropertyGroup>

  <!-- Config -->
  <PropertyGroup>
    <RepositoryName>NupkgWrench</RepositoryName>
    <PackageIconPath>$(MSBuildThisFileDirectory)/icons/icon.png</PackageIconPath>
  </PropertyGroup>

  <!-- Nuspec defaults -->
  <PropertyGroup>
    <Authors>emgarten</Authors>
    <PackageProjectUrl>https://github.com/emgarten/NupkgWrench</PackageProjectUrl>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/emgarten/NupkgWrench</RepositoryUrl>
    <PackageTags>nupkg;nuget-powertool</PackageTags>
    <Description>NupkgWrench is a cross platform command line tool to read and modify nupkgs.</Description>
  </PropertyGroup>

  <PropertyGroup>
    <NoWarn>$(NoWarn)</NoWarn>
  </PropertyGroup>

  <!-- Analyzers -->
   <PropertyGroup>
      <AnalysisMode>Recommended</AnalysisMode>
      <NoWarn>$(NoWarn);CA2211;CA1308;CA2007;CA1051</NoWarn>
   </PropertyGroup>
</Project>